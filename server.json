{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.UNIPaaS/paas-build-mcp",
  "description": "Your agent opens a real merchant account (go_live) and takes payments the same day. 3.9% flat.",
  "version": "0.1.3",
  "websiteUrl": "https://paas.build/agents",
  "repository": {
    "url": "https://github.com/UNIPaaS/paas-build-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@paasbuild/mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PAAS_PROXY",
          "description": "paas.build API base (secrets stay server-side).",
          "isRequired": false,
          "default": "https://api.paas.build"
        }
      ]
    }
  ]
}