{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.unipaas/paas-build-mcp",
  "description": "Your AI agent takes a business live on payments: go_live creates a real merchant account (sandbox + production) the same day; create_checkout returns a payable link. Payments for AI builders, 3.9% flat.",
  "version": "0.1.1",
  "websiteUrl": "https://paas.build/agents",
  "repository": {
    "url": "https://github.com/UNIPaaS/paas-build-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@paasbuild/mcp",
      "version": "0.1.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "PAAS_PROXY",
          "description": "paas.build API base (secrets stay server-side).",
          "isRequired": false,
          "default": "https://api.paas.build"
        }
      ]
    }
  ]
}
